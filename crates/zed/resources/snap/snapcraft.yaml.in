name: tungsten
title: Tungsten
base: core24
version: "$RELEASE_VERSION"
summary: A high-performance, GPU-rendered note-taking app and code editor
description: |
  Tungsten is a free and open-source, local-first personal knowledge application,
  built by forking the Zed editor (Rust + GPUI) and layering a
  personal-knowledge-management stack on top: vault concept, Live Preview
  Markdown, wikilinks, graph, Canvas, Bases, and an isolated Obsidian compat
  subsystem that runs unmodified Obsidian plugins. Drop-in compatibility with
  Obsidian vaults.
grade: stable
confinement: classic
compression: lzo
website: https://github.com/fuegocoding/tungsten
source-code: https://github.com/fuegocoding/tungsten
issues: https://github.com/fuegocoding/tungsten/issues
contact: https://github.com/fuegocoding/tungsten/discussions

parts:
  tungsten:
    plugin: dump
    source: "https://github.com/fuegocoding/tungsten/releases/download/v$RELEASE_VERSION/tungsten-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it Tungsten exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it Tungsten exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  tungsten:
    command: usr/bin/tungsten
    common-id: dev.tungsten.Tungsten
    environment:
      ZED_BUNDLE_TYPE: snap
