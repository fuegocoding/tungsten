[Desktop Entry]
Version=1.0
Type=Application
Name=$APP_NAME
GenericName=Text Editor
Comment=A high-performance, GPU-rendered note-taking app and code editor.
TryExec=$APP_CLI
StartupNotify=$DO_STARTUP_NOTIFY
Exec=$APP_CLI $APP_ARGS
Icon=$APP_ICON
Categories=Utility;TextEditor;Development;IDE;Note-taking;
Keywords=tungsten;notes;markdown;obsidian;pkm;
# To add Tungsten to "Open Folder With..." context menu, add `inode/directory` to the MimeType field (semicolon separated)
MimeType=text/plain;text/markdown;application/x-zerosize;x-scheme-handler/tungsten;x-scheme-handler/zed;
Actions=NewWorkspace;

[Desktop Action NewWorkspace]
Exec=$APP_CLI --new $APP_ARGS
Name=Open a new workspace
